<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Orchestrator"
            android:textColor="#14b8a6"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:gravity="center" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="#aaaaaa"
            app:boxBackgroundColor="#1f2937"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#14b8a6">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/queryInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. mujhe ac theek karwana hai"
                android:textColor="#ffffff"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/orchestrateBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Orchestrate Request"
            android:backgroundTint="#0d9488"
            android:textColor="#ffffff"
            android:textSize="16sp"
            app:cornerRadius="12dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="#14b8a6" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ef4444"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:padding="12dp"
            android:background="#3b0726" />

        <!-- Results Container -->
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:visibility="gone">

            <!-- Step 1: Intent -->
            <TextView
                android:id="@+id/intentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e5e7eb"
                android:background="#1f2937"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:textSize="14sp" />

            <!-- Step 2: Match -->
            <TextView
                android:id="@+id/matchText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e5e7eb"
                android:background="#1f2937"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:textSize="14sp" />

            <!-- Step 3: Price -->
            <TextView
                android:id="@+id/priceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e5e7eb"
                android:background="#1f2937"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:textSize="14sp" />

            <!-- Step 4: Booking -->
            <TextView
                android:id="@+id/bookingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e5e7eb"
                android:background="#1f2937"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:textSize="14sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
